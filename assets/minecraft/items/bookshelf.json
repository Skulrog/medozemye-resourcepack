{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Bookshelf with nothing", "Книжная полка с ничем" ],
					"model": {
						"type": "model",
						"model": "item/bookshelf/bookshelf_0"
					}
				},
				{
					"when": [ "Bookshelf with azalea", "Книжная полка с азалией" ],
					"model": {
						"type": "model",
						"model": "item/bookshelf/bookshelf_2"
					}
				},
				{
					"when": [ "Bookshelf with box", "Книжная полка с коробочкой" ],
					"model": {
						"type": "model",
						"model": "item/bookshelf/bookshelf_corobok"
					}
				},
				{
					"when": [ "Bookshelf with jewelry", "Книжная полка с драгоценностями" ],
					"model": {
						"type": "model",
						"model": "item/bookshelf/bookshelf_dragocennosti"
					}
				},
				{
					"when": [ "Bookshelf with papers", "Книжная полка с бумагами" ],
					"model": {
						"type": "model",
						"model": "item/bookshelf/bookshelf_paper"
					}
				},
				{
					"when": [ "Bookshelf with cobwebs", "Книжная полка с паутиной" ],
					"model": {
						"type": "model",
						"model": "item/bookshelf/bookshelf_pautina"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "block/bookshelf"
			}
		},
		"on_false": {
			"type": "model",
			"model": "block/bookshelf"
		}
	}
}