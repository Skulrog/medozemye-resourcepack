{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Webber", "Веббер" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/webber/webber"
					}
				},
				{
					"when": [ "Webber Black hat", "Веббер Блек хет" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/webber/webber_black_hat"
					}
				},
				{
					"when": [ "Webber Blin", "Веббер Блин" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/webber/webber_blin"
					}
				},
				{
					"when": [ "Webber christmas", "Веббер новый год" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/webber/webber_christmas"
					}
				},
				{
					"when": [ "Webber mafiozi", "Веббер мафиози" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/webber/webber_mafiozi"
					}
				},
				{
					"when": [ "Webber stroitel", "Веббер строитель" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/webber/webber_stroitel"
					}
				},
				{
					"when": [ "Webber th" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/webber/webber_th"
					}
				},
				{
					"when": [ "Son christmas", "Сон новый год" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/son/son_christmas"
					}
				},
				{
					"when": [ "Son classic", "Сон классический" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/son/son_n_n_classic"
					}
				},
				{
					"when": [ "Son hood", "Сон в капюшоне" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/son/son_n_n_hood"
					}
				},
				{
					"when": [ "Son mafiozi", "Сон мафиози" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/son/son_n_n_mafiozi"
					}
				},
				{
					"when": [ "Son stroitel", "Сон строитель" ],
					"model": {
						"type": "model",
						"model": "item/totem_of_undying/son/son_n_n_stroitel"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/totem_of_undying"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/totem_of_undying"
		}
	}
}