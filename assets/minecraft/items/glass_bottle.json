{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Empty jar", "Пустая банка" ],
					"model": {
						"type": "model",
						"model": "item/glass_bottle/banka_0"
					}
				},
				{
					"when": [ "Honey jar", "Банка мёда" ],
					"model": {
						"type": "model",
						"model": "item/glass_bottle/banka_meda"
					}
				},
				{
					"when": [ "Jam jar", "Банка варенья" ],
					"model": {
						"type": "model",
						"model": "item/glass_bottle/banka_varenya"
					}
				},
				{
					"when": [ "Glass", "Бокал" ],
					"model": {
						"type": "model",
						"model": "item/glass_bottle/bockal"
					}
				},
				{
					"when": [ "Bonk", "Бонк" ],
					"model": {
						"type": "model",
						"model": "item/glass_bottle/bonk0"
					}
				},
				{
					"when": [ "Mug", "Кружка" ],
					"model": {
						"type": "model",
						"model": "item/glass_bottle/cup0"
					}
				},
				{
					"when": [ "Cup", "Стакан" ],
					"model": {
						"type": "model",
						"model": "item/glass_bottle/stackan"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/glass_bottle"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/glass_bottle"
		}
	}
}