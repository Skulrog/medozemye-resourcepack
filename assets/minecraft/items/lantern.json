{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Kerosene lamp", "Керосиновая лампа" ],
					"model": {
						"type": "model",
						"model": "item/lantern/cerosin_lamp"
					}
				},
				{
					"when": [ "Kerosene lamp off", "Керосиновая лампа выключена" ],
					"model": {
						"type": "model",
						"model": "item/lantern/cerosin_lamp_0"
					}
				},
				{
					"when": [ "Kerosene lamp soul", "Керосиновая лампа душ" ],
					"model": {
						"type": "model",
						"model": "item/lantern/cerosin_lamp_soul"
					}
				},
				{
					"when": [ "Table lamp", "Настольная лампа" ],
					"model": {
						"type": "model",
						"model": "item/lantern/nastol_lamp"
					}
				},
				{
					"when": [ "Table lamp raised", "Настольная лампа поднята" ],
					"model": {
						"type": "model",
						"model": "item/lantern/nastol_lamp_up"
					}
				},
				{
					"when": [ "Green lamp", "Зелёная лампа" ],
					"model": {
						"type": "model",
						"model": "item/lantern/svetilnik"
					}
				},
				{
					"when": [ "Japanese lantern", "Японский фонарь" ],
					"model": {
						"type": "model",
						"model": "item/lantern/svetilnik_japan"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/lantern"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/lantern"
		}
	}
}