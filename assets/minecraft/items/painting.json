{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Paintbrush", "Кисточка" ],
					"model": {
						"type": "model",
						"model": "item/painting/paintbrush"
					}
				},
				{
					"when": "1.20",
					"model": {
						"type": "model",
						"model": "item/painting/1.20"
					}
				},
				{
					"when": [ "Cats", "Котики" ],
					"model": {
						"type": "model",
						"model": "item/painting/animals"
					}
				},
				{
					"when": "Euphorium 3",
					"model": {
						"type": "model",
						"model": "item/painting/ep_3"
					}
				},
				{
					"when": [ "Fox", "Лисичка" ],
					"model": {
						"type": "model",
						"model": "item/painting/fox"
					}
				},
				{
					"when": "ilyyshka",
					"model": {
						"type": "model",
						"model": "item/painting/ilyyshka"
					}
				},
				{
					"when": [ "Sunflower", "Подсолнух" ],
					"model": {
						"type": "model",
						"model": "item/painting/sunflower"
					}
				},
				{
					"when": [ "Wandering Trader", "Странствующий торговец" ],
					"model": {
						"type": "model",
						"model": "item/painting/trader"
					}
				},
				{
					"when": [ "Webber", "Веббер" ],
					"model": {
						"type": "model",
						"model": "item/painting/webber"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/painting"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/painting"
		}
	}
}