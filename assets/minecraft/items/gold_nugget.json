{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Ring", "Кольцо" ],
					"model": {
						"type": "model",
						"model": "item/gold_nugget/ring"
					}
				},
				{
					"when": [ "Wedding ring", "Обручальное кольцо" ],
					"model": {
						"type": "model",
						"model": "item/gold_nugget/wedding_ring"
					}
				},
				{
					"when": [ "Coin", "Монетка" ],
					"model": {
						"type": "model",
						"model": "item/gold_nugget/coin"
					}
				},
				{
					"when": [ "Gold coins", "Золотые монеты" ],
					"model": {
						"type": "model",
						"model": "item/gold_nugget/coins"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/gold_nugget"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/gold_nugget"
		}
	}
}