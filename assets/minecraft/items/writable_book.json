{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "scroll_bundle", "scroll bundle", "♈ Футляр для свитков ♈", "Футляр для свитков" ],
					"model": {
						"type": "model",
						"model": "item/scroll_bundle"
					}
				},
				{
					"when": [ "scroll_water", "♈ Свиток воды ♈" ],
					"model": {
						"type": "model",
						"model": "item/scroll_water"
					}
				},
				{
					"when": [ "scroll_fire", "♈ Свиток огня ♈" ],
					"model": {
						"type": "model",
						"model": "item/scroll_fire"
					}
				},
				{
					"when": [ "scroll_air", "♈ Свиток воздуха ♈" ],
					"model": {
						"type": "model",
						"model": "item/scroll_air"
					}
				},
				{
					"when": [ "scroll_plant", "♈ Свиток природы ♈" ],
					"model": {
						"type": "model",
						"model": "item/scroll_plant"
					}
				},
				{
					"when": [ "scroll", "♈ Свиток ♈" ],
					"model": {
						"type": "model",
						"model": "item/scroll_air"
					}
				},
				{
					"when": [ "Webber izralityan", "Веббер izralityan" ],
					"model": {
						"type": "model",
						"model": "item/book"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/writable_book"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/writable_book"
		}
	}
}