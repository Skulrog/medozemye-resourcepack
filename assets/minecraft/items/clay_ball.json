{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "money_gold",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:selected",
          "on_true": {
            "type": "minecraft:model",
            "model": "custommodel:item/money_gold"
          },
		  "on_false": {
            "type": "minecraft:model",
            "model": "custommodel:item/money_gold"
          }
        }
      },
      {
        "when": "money_silver",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:selected",
          "on_true": {
            "type": "minecraft:model",
            "model": "custommodel:item/money_silver"
          },
		  "on_false": {
            "type": "minecraft:model",
            "model": "custommodel:item/money_silver"
          }
        }
      },
	  {
        "when": "money_bronze",
        "model": {
          "type": "minecraft:condition",
          "property": "minecraft:selected",
          "on_true": {
            "type": "minecraft:model",
            "model": "custommodel:item/money_bronze"
          },
		  "on_false": {
            "type": "minecraft:model",
            "model": "custommodel:item/money_bronze"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/clay_ball"
    }
  }
}