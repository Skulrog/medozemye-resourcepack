{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Nigiri", "Нигири" ],
					"model": {
						"type": "model",
						"model": "item/salmon/nigiri"
					}
				},
				{
					"when": [ "Onigiri", "Онигири" ],
					"model": {
						"type": "model",
						"model": "item/salmon/onigiri"
					}
				},
				{
					"when": [ "Rolls", "Роллы" ],
					"model": {
						"type": "model",
						"model": "item/salmon/rolls"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/salmon"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/salmon"
		}
	}
}