{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Pancakes", "Блины" ],
					"model": {
						"type": "model",
						"model": "item/bread/blins"
					}
				},
				{
					"when": [ "Chocolate pancakes", "Шоколадные блины" ],
					"model": {
						"type": "model",
						"model": "item/bread/blins_chocolate"
					}
				},
				{
					"when": [ "Cupcake", "Кекс" ],
					"model": {
						"type": "model",
						"model": "item/bread/keks"
					}
				},
				{
					"when": [ "Piece of cake", "Кусок торта" ],
					"model": {
						"type": "model",
						"model": "item/bread/piece_cake"
					}
				},
				{
					"when": [ "Chocolate piece of cake", "Шоколадный кусок торта" ],
					"model": {
						"type": "model",
						"model": "item/bread/chocolate_piece_cake"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/bread"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/bread"
		}
	}
}