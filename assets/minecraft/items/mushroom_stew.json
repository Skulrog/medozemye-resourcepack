{
	"model": {
		"type": "condition",
		"property": "has_component",
		"component": "custom_name",
		"on_true": {
			"type": "select",
			"property": "component",
			"component": "custom_name",
			"cases": [
				{
					"when": [ "Multi salad", "Мульти салат" ],
					"model": {
						"type": "model",
						"model": "item/mushroom_stew/salat1_bowl"
					}
				},
				{
					"when": [ "Light salad", "Лёгкий салат" ],
					"model": {
						"type": "model",
						"model": "item/mushroom_stew/salat2_bowl"
					}
				},
				{
					"when": [ "Salmon in a bowl", "Лосось в миске" ],
					"model": {
						"type": "model",
						"model": "item/mushroom_stew/losos_bowl"
					}
				}
			],
			"fallback": {
				"type": "model",
				"model": "item/mushroom_stew"
			}
		},
		"on_false": {
			"type": "model",
			"model": "item/mushroom_stew"
		}
	}
}